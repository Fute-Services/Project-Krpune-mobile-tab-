{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview-tablet": {
      "extends": "preview",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "tablet"
      }
    },
    "preview-mobile": {
      "extends": "preview",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "mobile"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      }
    },
    "production-tablet": {
      "extends": "production",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "tablet"
      }
    },
    "production-mobile": {
      "extends": "production",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "mobile"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
