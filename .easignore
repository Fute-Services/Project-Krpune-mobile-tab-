# EAS Build upload ignore. Keeps the project tarball under the 2 GB limit.
# When this file exists it governs what EAS uploads, so it must repeat the
# .gitignore excludes plus the big local-only folders.

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# generated native folders (regenerated by prebuild on EAS)
/ios
/android

# Native / keys
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro / debug
.metro-health-check*
npm-debug.*
yarn-debug.*
yarn-error.*

# misc
.DS_Store
*.pem
.env*.local
.env
*.tsbuildinfo
scripts/.img-backup/

# Local-only: downloaded release APKs and stale native copy — huge, never needed in a build
releases/
*.apk
android_stale_144035520/
